def cons(arr):
    s=set()
    cnt=0
    longest=0
    x=0
    if len(arr)==0:
        return 0
    for i in arr:
        s.add(i)
    for i in s:
        if i-1 not in s:
            cnt=1
            x=i
            while x+1 in s:
                cnt+=1
                x+=1
            longest=max(longest,cnt)
    return longest
arr=[100, 4, 200, 1, 3, 2]  
print(cons(arr))
