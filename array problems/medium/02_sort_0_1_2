def sort_1(arr):
    low=0
    mid=0
    high=len(arr)-1
    while mid<high:
        if arr[mid]==0:
            arr[low],arr[mid]=arr[mid],arr[low]
            mid+=1
            low+=1
        elif arr[mid]==1:
            mid+=1
        elif arr[mid]==2:
            arr[mid],arr[high]=arr[high],arr[mid]
            mid+=1
            high-=1
    return arr
arr = [2, 0, 2, 1, 1, 0]
print(sort_1(arr))