def merges(arr1, arr2):
    n = len(arr1) - 1
    m = 0

    while n >= 0 and m < len(arr2):

        if arr1[n] > arr2[m]:
            arr1[n], arr2[m] = arr2[m], arr1[n]
            n -= 1
            m += 1
        else:
            break

    arr1.sort()
    arr2.sort()

    return arr1, arr2

arr1 = [1,3,5,7]
arr2 = [0,2,6,8,9]

print(merges(arr1, arr2))