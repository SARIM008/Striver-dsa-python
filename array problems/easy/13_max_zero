def maxzero(arr):
    m={}
    maxlen=0
    sum=0
    for i in range(len(arr)):
        sum+=arr[i]

        if sum==0:
            maxlen=i+1
        else:
            if sum in m:
                maxlen=max(maxlen,i-m[sum])
            else:
                m[sum]=i
    return maxlen

arr = [9, -3, 3, -1, 6, -5]
print(maxzero(arr))
