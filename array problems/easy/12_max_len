def maxlen(arr,n):
    left=0
    right=0
    sum=arr[0]
    maxl=0
    while (right<len(arr)):
        if sum>n:
            sum-=arr[left]
            left+=1
        if sum==n:
            maxl=max(maxl,right-left+1)
        right+=1
        if right<len(arr):
            sum+=arr[right]
    return maxl

arr = [10, 5, 2, 7, 1, 9]
n = 15
print(maxlen(arr,n))