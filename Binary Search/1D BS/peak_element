def findPeakElement(nums):
        # Set left and right bounds
    low, high = 0, len(nums) - 1

        # Binary search loop
    while low < high:
            # Find mid point
        mid = (low + high) // 2

            # If mid element is greater than next
        if nums[mid] > nums[mid + 1]:
                # Move to left half
            high = mid
        else:
                # Move to right half
            low = mid + 1

        # Return peak index
    return low

nums = [1, 2, 1, 3, 5, 6, 4]
print(findPeakElement(nums))